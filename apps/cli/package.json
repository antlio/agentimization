  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agentimization": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antlio/agentimization.git",
